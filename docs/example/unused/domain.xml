<?xml version="1.0" encoding="UTF-8"?>
<schema>
    <table>
        <name>domain</name>
        <type>InnoDB</type>
        <collation>utf8mb4_general_ci</collation>
        <comment>A table for storing domain list</comment>
    </table>
    <columns>
        <domain_id>
            <type>integer(11)</type>
            <index>primary</index>
            <autoincrement>true</autoincrement>
        </domain_id>
        <user_id>
            <type>integer(11)</type>
            <index>index</index>
        </user_id>
        <name>
            <type>string(255)</type>
            <collation>utf8mb4_general_ci</collation>
            <index>index</index>
        </name>
        <description>
            <type>text</type>
            <collation>utf8mb4_general_ci</collation>
        </description>
        <account>
            <type>string(255)</type>
            <collation>utf8mb4_general_ci</collation>
            <index>index</index>
        </account>
        <expiration_date>
            <type>integer(11)</type>
            <index>index</index>
        </expiration_date>
        <note_id>
            <type>integer(11)</type>
            <index>index</index>
        </note_id>
        <position>
            <type>integer(11)</type>
            <index>index</index>
        </position>
        <status>
            <type>tinyint(1)</type>
            <index>index</index>
        </status>
        <deleted_by>
            <type>integer(11)</type>
            <index>index</index>
        </deleted_by>
        <deleted_on>
            <type>integer(11)</type>
            <index>index</index>
        </deleted_on>
    </columns>
    <relations>
        <account_account>
            <foreign>account_id</foreign>
            <foreignType>one</foreignType>
            <type>one</type>
        </account_account>
    </relations>
</schema>
